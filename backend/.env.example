# =============================================================================
# Zentivra - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# Database
# For SQLite (development):
DATABASE_URL=sqlite+aiosqlite:///./zentivra.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/zentivra

# LLM Provider
# Optional explicit provider override:
#   LLM_PROVIDER=openrouter
# Supported values: openrouter, groq, gemini, openai, anthropic
# LLM_PROVIDER=
GROQ_API_KEY=your-groq-api-key-here
OPENROUTER_API_KEY=your-openrouter-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional model overrides (advanced)
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
# GEMINI_MODEL=gemini-2.0-flash-lite
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Email Delivery (pick one)
# Option A: SendGrid (recommended)
SENDGRID_API_KEY=your-sendgrid-api-key-here
EMAIL_FROM=zentivra@yourdomain.com
# Option B: SMTP (e.g., Gmail)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# SMTP_TIMEOUT_SECONDS=30
# EMAIL_FROM=you@gmail.com

# Email Recipients (comma-separated)
EMAIL_RECIPIENTS=user@example.com

# Optional API Keys
SEMANTIC_SCHOLAR_API_KEY=
HUGGINGFACE_TOKEN=

# Scheduling
DIGEST_TIME=06:00
TIMEZONE=Asia/Kolkata

# App Settings
APP_ENV=development
LOG_LEVEL=INFO
MAX_PAGES_PER_DOMAIN=50
DEFAULT_RATE_LIMIT_RPM=10
ENABLE_SEMANTIC_DEDUP=false

# Runtime safety limits (prevents long, expensive runs)
MAX_URLS_PER_SOURCE=3
URL_PROCESSING_TIMEOUT_SECONDS=90
SOURCE_PROCESSING_TIMEOUT_SECONDS=300
AGENT_TIMEOUT_SECONDS=1200
HTTP_FETCH_TIMEOUT_SECONDS=20
HTTP_FETCH_MAX_RETRIES=2
LLM_TIMEOUT_SECONDS=45
MAX_LLM_RANKINGS_PER_RUN=12
STALE_RUN_TIMEOUT_SECONDS=1800
