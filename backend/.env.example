# =============================================================================
# Zentivra - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# Database (PostgreSQL via Aiven)
DATABASE_URL=postgresql+asyncpg://user:pass@host:port/dbname

# SSL certificate for PostgreSQL (optional -- falls back to ssl=require if unset)
# Local:  DATABASE_CA_CERT_PATH=certs/ca.pem
# Render: DATABASE_CA_CERT_PATH=/etc/secrets/ca.pem
DATABASE_CA_CERT_PATH=

# LLM Provider
# Optional explicit provider override:
#   LLM_PROVIDER=openrouter
# Supported values: openrouter, groq, gemini, openai, anthropic
# LLM_PROVIDER=
GROQ_API_KEY=your-groq-api-key-here
OPENROUTER_API_KEY=your-openrouter-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional model overrides (advanced)
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
# GEMINI_MODEL=gemini-2.0-flash-lite
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Email Delivery (pick one — Brevo recommended for speed)
# Option A: Brevo API (recommended — fastest, free 300 emails/day)
BREVO_API_KEY=your-brevo-api-key-here
EMAIL_FROM=zentivra@yourdomain.com
# Option B: SendGrid API (legacy)
# SENDGRID_API_KEY=your-sendgrid-api-key-here
# Option C: SMTP (e.g., Brevo SMTP, Gmail, or any provider)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-brevo-login-email
# SMTP_PASSWORD=your-brevo-smtp-key
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# SMTP_TIMEOUT_SECONDS=30

# Email Recipients (comma-separated)
EMAIL_RECIPIENTS=user@example.com

# Optional API Keys
SEMANTIC_SCHOLAR_API_KEY=
HUGGINGFACE_TOKEN=

# Scheduling
DIGEST_TIME=06:00
TIMEZONE=Asia/Kolkata

# Auth / Valkey (Aiven)
VALKEY_URL=rediss://default:pass@host:port/0
AUTH_TOKEN_TTL_HOURS=2

# CORS — comma-separated list of allowed frontend origins
# In production: set this to your Vercel URL (e.g. https://zentivra.vercel.app)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# App Settings
APP_ENV=development
LOG_LEVEL=INFO
MAX_PAGES_PER_DOMAIN=50
DEFAULT_RATE_LIMIT_RPM=10
ENABLE_SEMANTIC_DEDUP=false

# Runtime safety limits (prevents long, expensive runs)
MAX_URLS_PER_SOURCE=3
URL_PROCESSING_TIMEOUT_SECONDS=90
SOURCE_PROCESSING_TIMEOUT_SECONDS=300
AGENT_TIMEOUT_SECONDS=1200
HTTP_FETCH_TIMEOUT_SECONDS=20
HTTP_FETCH_MAX_RETRIES=2
LLM_TIMEOUT_SECONDS=45
MAX_LLM_RANKINGS_PER_RUN=12
STALE_RUN_TIMEOUT_SECONDS=1800
