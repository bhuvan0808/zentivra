# =============================================================================
# Zentivra - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# Database
# For SQLite (development):
DATABASE_URL=sqlite+aiosqlite:///./zentivra.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/zentivra

# LLM Provider (pick one, uncomment the one you want to use)
GEMINI_API_KEY=your-gemini-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Email Delivery (pick one)
# Option A: SendGrid (recommended)
SENDGRID_API_KEY=your-sendgrid-api-key-here
EMAIL_FROM=zentivra@yourdomain.com
# Option B: SMTP (e.g., Gmail)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=you@gmail.com

# Email Recipients (comma-separated)
EMAIL_RECIPIENTS=user@example.com

# Optional API Keys
SEMANTIC_SCHOLAR_API_KEY=
HUGGINGFACE_TOKEN=

# Scheduling
DIGEST_TIME=06:00
TIMEZONE=Asia/Kolkata

# App Settings
APP_ENV=development
LOG_LEVEL=INFO
MAX_PAGES_PER_DOMAIN=50
DEFAULT_RATE_LIMIT_RPM=10
